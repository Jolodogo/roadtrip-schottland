# Supabase – findest du in deinem Supabase Projekt unter Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key-hier
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key-hier

# Dein geheimer Passcode zum Posten (mind. 6 Zeichen empfohlen)
ADMIN_PASSCODE=euer-geheimer-reise-passcode

# Push-Benachrichtigungen (VAPID)
# Keys generieren: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<public-key>
VAPID_PRIVATE_KEY=<private-key>
VAPID_SUBJECT=mailto:cordes.john@web.de
